# ╔══════════════════════════════════════════════════════════╗
# ║  Voice Concierge — environment template                  ║
# ║  Copy this file to `.env` and fill in real values.       ║
# ╚══════════════════════════════════════════════════════════╝

# ──── Postgres ────
POSTGRES_USER=concierge
POSTGRES_PASSWORD=concierge_dev_pwd
POSTGRES_DB=concierge

# ──── Backend (.NET) ────
# Connection string is assembled from POSTGRES_* inside docker-compose.yml.
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# Shared secret for agent → backend auth (X-Agent-Secret header).
# Generate with:  openssl rand -hex 32
AGENT_SHARED_SECRET=replace_me_with_a_long_random_string

# ──── OpenAI (LLM + embeddings) ────
OpenAI__ApiKey=sk-...
OpenAI__ChatModel=gpt-4.1
OpenAI__EmbeddingModel=text-embedding-3-small

# ──── LiveKit Cloud ────
# Get these at https://cloud.livekit.io → Project → Settings → API keys.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxx
LIVEKIT_API_SECRET=secret_xxxxxxxxxxxxxx

# ──── ElevenLabs (TTS) ────
# Free tier accounts can only use *stock* voices via API (not library voices).
# These four IDs are tested stock voices matching the PRD personalities:
#   James (mature British male)        → Daniel
#   Sofia (warm female, European tone) → Lily
#   Marcus (American male, confident)  → Adam
#   Elena (American female, calm)      → Sarah
ElevenLabs__ApiKey=sk_...
ElevenLabs__VoiceJames=onwK4e9ZLuTAKqWW03F9
ElevenLabs__VoiceSofia=pFZP5JQG7iQjIQuC4Bku
ElevenLabs__VoiceMarcus=pNInz6obpgDQGcFmaJgB
ElevenLabs__VoiceElena=EXAVITQu4vr4xnSDxMaL

# ──── Deepgram (STT) ────
DEEPGRAM_API_KEY=...

# ──── Agent (consumes shared secret + service URLs via env) ────
BACKEND_URL=http://backend:8080
